fn calculate_pi(n: int) {
    mut pi = 0.0
    mut divisor = 1.0
    for i in range(n) {
        if i % 2 == 0 {
            pi = pi + 1.0 / divisor
        } else {
            pi = pi - 1.0 / divisor
        }
        divisor = divisor + 2.0
    }
    return 4.0 * pi
}

let n = 10000000
let result = calculate_pi(n)
print("Pi:", result)
