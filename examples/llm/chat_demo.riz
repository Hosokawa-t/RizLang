import_native "plugin_llama_cli.dll"

# リポジトリルートを cwd にして実行する想定
let cli = "tools/llama_test/bin/llama-completion.exe"
let model = "tools/llama_test/model.gguf"

llama_set_cli(cli)
llama_set_gpu_layers(32) # GPUレイヤー数を指定（32層をVRAMへ）

print("============================================================")
print("  Riz Native LLM Chat Demo")
print("============================================================")
print("Model:", model)
print("Note: GPU Acceleration enabled (-ngl 32)")
print("Note: Put your GGUF model at tools/llama_test/model.gguf")
print("============================================================")

mut running = true
while running {
    # input() を使うと対話的に入力を受け取れます
    print("\n[You]")
    let user_input = input("> ")
    
    if user_input == "" {
        running = false
    } else {
        if user_input == "exit" {
            running = false
        } else {
            print("\n[Riz AI thinking...]")
            # llama_infer(model_path, prompt, max_tokens)
            let response = llama_infer(model, user_input, 64)
            print("\n[AI Response]")
            print(response)
        }
    }
}

print("\nChat ended.")
