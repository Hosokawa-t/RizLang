# ─── FizzBuzz in Riz ──────────────────────────
# The classic coding interview problem

fn fizzbuzz(n) {
    for i in range(1, n + 1) {
        if i % 15 == 0 {
            print("FizzBuzz")
        } else if i % 3 == 0 {
            print("Fizz")
        } else if i % 5 == 0 {
            print("Buzz")
        } else {
            print(i)
        }
    }
}

print("FizzBuzz 1-30:")
print("─────────────")
fizzbuzz(30)
