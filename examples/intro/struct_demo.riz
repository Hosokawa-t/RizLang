# Struct typing for AOT / native-style handles (see README and codegen).
# For loading a .dll/.so plugin, see examples/intro/phase5_demo.riz (import_native).

struct Memory {
    opaque: int
}

struct Tensor {
    size: int
    data: int
}

mut ptr: Memory = Memory(0)
mut tensor: Tensor = Tensor(0, 0)
tensor.size = 100
tensor.data = 0

print("struct_demo: Tensor size=", tensor.size, "data=", tensor.data)
input()
