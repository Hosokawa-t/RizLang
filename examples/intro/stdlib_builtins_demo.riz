# Extended builtins (interpreter + VM). Run: riz examples/intro/stdlib_builtins_demo.riz  |  riz --vm examples/intro/stdlib_builtins_demo.riz
print(clamp(10, 0, 5))
print(sign(-4))
let xs = [0, 1, 2]
append(xs, 4)
print(len(xs))
print(ord("A"))
print(chr(65))
print(all(range(0)))
print(any(range(2)))
