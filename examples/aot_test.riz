# ─── Riz AOT Compilation Test ────────────────
# Compile with: riz --aot examples/aot_test.riz
# This produces a standalone native binary!

print("═══════════════════════════════════════")
print("  Riz AOT — Native Binary Output!")
print("═══════════════════════════════════════")

# Arithmetic (compiled directly to C math)
print("")
print("▸ Arithmetic (native speed)")
print("  2 + 3 =", 2 + 3)
print("  10 - 4 =", 10 - 4)
print("  6 * 7 =", 6 * 7)
print("  15 / 4 =", 15 / 4)
print("  17 % 5 =", 17 % 5)
print("  2 ** 10 =", 2 ** 10)

# Variables
print("")
print("▸ Variables")
let x = 42
let y = 3.14
let name = "Riz Native"
print("  x =", x)
print("  y =", y)
print("  name =", name)

# Comparisons
print("")
print("▸ Comparisons")
print("  5 == 5:", 5 == 5)
print("  5 != 3:", 5 != 3)
print("  3 < 5:", 3 < 5)

# If/Else
print("")
print("▸ Control Flow")
let score = 95
if score > 90 {
    print("  Grade: A")
} else {
    if score > 80 {
        print("  Grade: B")
    } else {
        print("  Grade: C")
    }
}

# While loop
print("")
print("▸ While Loop: Sum 1..10")
mut total = 0
mut i = 1
while i <= 10 {
    total = total + i
    i = i + 1
}
print("  Sum =", total)

# String ops
print("")
print("▸ Strings")
print("  " + "Hello" + " " + "from" + " " + "native" + " " + "code!")

print("")
print("═══════════════════════════════════════")
print("  AOT Compilation Successful! ✓")
print("  This is a STANDALONE .exe binary!")
print("═══════════════════════════════════════")
